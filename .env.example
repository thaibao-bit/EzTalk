# Public port for FastAPI; port 8000 remains available to vLLM.
API_PORT=8080

# From the FastAPI container to a vLLM server on the host machine.
VLLM_BASE_URL=http://host.docker.internal:8000/v1

# Must match the model name exposed by GET /v1/models or --served-model-name.
VLLM_MODEL=default

# Optional unless vLLM was started with --api-key.
VLLM_API_KEY=
